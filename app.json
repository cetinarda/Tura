{
  "expo": {
    "name": "Sakin Hayvan Rehberi",
    "slug": "sakin-animals",
    "scheme": "sakin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0B14"
    },
    "ios": {
      "bundleIdentifier": "life.sakin.animals",
      "buildNumber": "1",
      "supportsTablet": true,
      "minimumOsVersion": "15.1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSMotionUsageDescription": "Tura uses motion data to detect when you shake your phone to draw the day's guidance card.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIRequiresFullScreen": false
      }
    },
    "android": {
      "package": "life.sakin.animals",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2e2540"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.VIBRATE"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_CALL_LOG",
        "android.permission.WRITE_CALL_LOG"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "platforms": ["ios", "android", "web"],
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#DAAF5C",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "extra": {
      "supportUrl": "https://sakin.life/support",
      "privacyUrl": "https://sakin.life/privacy",
      "termsUrl": "https://sakin.life/terms",
      "eas": {
        "projectId": ""
      }
    }
  }
}
