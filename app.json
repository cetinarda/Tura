{
  "expo": {
    "name": "Sakin Hayvan Rehberi",
    "slug": "sakin-animals",
    "scheme": "sakin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0B14"
    },
    "ios": {
      "bundleIdentifier": "life.sakin.animals",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "associatedDomains": ["applinks:sakin.life"],
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Günlük hayvan rehberliği hatırlatması için bildirim izni."
      }
    },
    "android": {
      "package": "life.sakin.animals",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2e2540"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "sakin.life", "pathPrefix": "/animals" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "color": "#C9A84C"
        }
      ]
    ]
  }
}
