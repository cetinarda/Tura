# Supabase project credentials (get from dashboard → Settings → API)
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe (get from dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (get from dashboard → Products)
# Create two products: "Sakin Mikro" (monthly) and "Sakin Premium" (yearly)
STRIPE_PRICE_MIKRO=price_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_SAKIN_ALL=price_...   # optional: bundle

# Mobile app RevenueCat keys (get from RevenueCat dashboard)
REVENUECAT_IOS_KEY=appl_...
REVENUECAT_ANDROID_KEY=goog_...
